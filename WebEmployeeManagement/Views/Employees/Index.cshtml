@model List<EmployeeList.Models.Employee>
@{
    Layout = null;
}

<h2>社員一覧</h2>
<table border="1">
    <thead>
        <tr>
            <th>社員ID</th>
            <th>氏名</th>
            <th>部署ID</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var employee in Model)
    {
        <tr>
            <td>@employee.EmployeeId</td>
            <td>@employee.EmployeeName</td>
            <td>@employee.DepartmentId</td>
        </tr>
    }
    </tbody>
</table>